# === 폴더 경로 (상대 경로면 프로젝트 루트 기준) ===
# 신규 오디오 파일을 떨어뜨릴 폴더. 감시 대상.
INBOX_DIR=inbox
# 처리 결과가 저장될 루트. outputs/<YYYY-MM-DD>/<HHMMSS-slug>/...
OUTPUT_DIR=outputs
# 처리 중 스테이징 폴더 (inbox → processing → outputs).
PROCESSING_DIR=processing
# 처리 완료된 원본을 옮길 폴더. "none" 으로 두면 처리 후 원본 삭제.
PROCESSED_DIR=processed
# 처리 실패한 원본을 옮길 폴더 (+.error.log 동봉).
FAILED_DIR=failed

# === Whisper ===
# 모델명: tiny / base / small / medium / large-v3 (기본 large-v3)
WHISPER_MODEL=large-v3
# 언어 코드 (예: ko, en, ja). "auto"면 자동 감지.
WHISPER_LANGUAGE=auto

# === Claude CLI ===
# 구독 인증(claude login) 재사용. ANTHROPIC_API_KEY 불필요.
ANTHROPIC_MODEL=sonnet
