# === Slack ===
# Bot OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Socket Mode App-Level Token (xapp-...) — connections:write 스코프 필요
SLACK_APP_TOKEN=xapp-your-app-token
# 반응할 단일 채널 ID (C0XXXXX). 다른 채널 이벤트는 무시됩니다.
SLACK_CHANNEL_ID=C0000000000

# === Whisper ===
# 모델명: tiny / base / small / medium / large-v3 (기본 large-v3)
WHISPER_MODEL=large-v3
# 언어 코드 (예: ko, en, ja). "auto"면 자동 감지.
WHISPER_LANGUAGE=auto

# === Claude CLI ===
# 구독 인증(claude login) 재사용. ANTHROPIC_API_KEY 불필요.
ANTHROPIC_MODEL=sonnet

# === 출력 경로 ===
# 절대/상대 경로. 기본은 프로젝트 루트의 outputs/
OUTPUT_DIR=outputs
